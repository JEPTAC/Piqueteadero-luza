rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userExists() {
      return signedIn() && exists(userPath());
    }

    function currentUser() {
      return get(userPath()).data;
    }

    function active() {
      return userExists() && currentUser().isActive == true;
    }

    function role() {
      return currentUser().role;
    }

    function superAdmin() {
      return active() && role() == 'super_admin';
    }

    function gerente() {
      return active() && role() == 'gerente';
    }

    function mesero() {
      return active() && role() == 'mesero';
    }

    function cajero() {
      return active() && role() == 'cajero';
    }

    function cocina() {
      return active() && role() == 'cocina';
    }

    function domicilio() {
      return active() && role() == 'domicilio';
    }

    function admin() {
      return active() && role() in ['super_admin', 'gerente'];
    }

    function cajaOAdmin() {
      return active() && role() in ['super_admin', 'gerente', 'cajero'];
    }

    function meseroOAdmin() {
      return active() && role() in ['super_admin', 'gerente', 'mesero'];
    }

    function cocinaOAdmin() {
      return active() && role() in ['super_admin', 'gerente', 'cocina'];
    }

    function domicilioOAdmin() {
      return active() && role() in ['super_admin', 'gerente', 'domicilio'];
    }

    function operacionGeneral() {
      return active() && role() in [
        'super_admin',
        'gerente',
        'mesero',
        'cajero',
        'cocina',
        'domicilio'
      ];
    }

    function onlyOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function cannotChangeRoleOrStatus() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['role', 'isActive', 'createdBy', 'createdAt']);
    }

    // =========================================================
    // USUARIOS INTERNOS
    // users/UID_DEL_USUARIO
    // =========================================================
    match /users/{uid} {
      allow read: if active() && (onlyOwner(uid) || admin());

      // El primer usuario lo puedes crear manualmente desde consola.
      // Luego, la Cloud Function createInternalUser crea los demás.
      allow create: if superAdmin();

      allow update: if superAdmin();

      allow update: if onlyOwner(uid)
        && active()
        && cannotChangeRoleOrStatus();

      allow delete: if superAdmin();
    }

    match /settings/{docId} {
      allow read: if operacionGeneral();
      allow create, update: if admin();
      allow delete: if superAdmin();
    }

    match /rooms/{docId} {
      allow read: if operacionGeneral();
      allow create, update: if admin() || mesero();
      allow delete: if admin();
    }

    match /restaurant_tables/{docId} {
      allow read: if operacionGeneral();
      allow create, update: if admin() || mesero();
      allow delete: if admin();
    }

    match /tables/{docId} {
      allow read: if operacionGeneral();
      allow create, update: if admin() || mesero();
      allow delete: if admin();
    }

    match /products/{docId} {
      allow read: if operacionGeneral();
      allow create, update, delete: if admin();
    }

    match /orders/{docId} {
      allow read: if operacionGeneral();
      allow create: if meseroOAdmin() || cajaOAdmin();
      allow update: if meseroOAdmin() || cocinaOAdmin() || cajaOAdmin();
      allow delete: if admin();
    }

    match /order_items/{docId} {
      allow read: if operacionGeneral();
      allow create: if meseroOAdmin() || cajaOAdmin();
      allow update: if meseroOAdmin() || cocinaOAdmin() || cajaOAdmin();
      allow delete: if admin() || mesero();
    }

    match /deliveries/{docId} {
      allow read: if admin() || domicilio() || cocina() || cajero();
      allow create: if domicilioOAdmin() || cajaOAdmin();
      allow update: if domicilioOAdmin() || cocinaOAdmin() || cajaOAdmin();
      allow delete: if admin();
    }

    match /delivery_items/{docId} {
      allow read: if admin() || domicilio() || cocina() || cajero();
      allow create: if domicilioOAdmin() || cajaOAdmin();
      allow update: if domicilioOAdmin() || cocinaOAdmin() || cajaOAdmin();
      allow delete: if admin();
    }

    match /customers/{docId} {
      allow read: if cajaOAdmin();
      allow create, update: if cajaOAdmin();
      allow delete: if admin();
    }

    match /credit_movements/{docId} {
      allow read: if cajaOAdmin();
      allow create: if cajaOAdmin();
      allow update, delete: if admin();
    }

    match /sales/{docId} {
      allow read: if cajaOAdmin();
      allow create: if cajaOAdmin();
      allow update, delete: if admin();
    }

    match /cash_sessions/{docId} {
      allow read: if cajaOAdmin();
      allow create, update: if cajaOAdmin();
      allow delete: if admin();
    }

    match /providers/{docId} {
      allow read, write: if admin();
    }

    match /expenses/{docId} {
      allow read, write: if admin();
    }

    match /employees/{docId} {
      allow read, write: if admin();
    }

    match /employee_payments/{docId} {
      allow read, write: if admin();
    }

    match /stock_movements/{docId} {
      allow read, write: if admin();
    }

    match /app_notifications/{docId} {
      allow read: if operacionGeneral();
      allow create, update: if operacionGeneral();
      allow delete: if admin();
    }

    match /notifications/{docId} {
      allow read: if operacionGeneral();
      allow create, update: if operacionGeneral();
      allow delete: if admin();
    }

    match /reports/{docId} {
      allow read, write: if admin();
    }

    match /audit_logs/{docId} {
      allow read: if admin();
      allow create: if operacionGeneral();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
