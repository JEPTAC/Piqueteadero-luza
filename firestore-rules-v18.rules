rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function myUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function active() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && myUser().isActive == true;
    }

    function role() {
      return myUser().role;
    }

    function superAdmin() {
      return active() && role() == 'super_admin';
    }

    function operation() {
      return active() && role() in ['super_admin','gerente','mesero','cajero','cocina','bar','domicilio'];
    }

    // Lectura pública para mostrar botones de usuario en el inicio.
    // No guardes contraseñas aquí.
    match /users/{uid} {
      allow read: if true;
      allow create, update, delete: if superAdmin();
    }

    // Estado operativo completo de la app.
    match /app_state/{docId} {
      allow read, write: if operation();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
